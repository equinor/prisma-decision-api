{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build PrismaApi.sln",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/PrismaApi/PrismaApi.sln"
      ],
      "group": "build",
      "problemMatcher": [
        "$msCompile"
      ]
    },
     {
        "label": "watch",
        "command": "dotnet",
        "type": "process",
        "args": [
            "watch",
            "run",
            "--project",
            "${workspaceFolder}/PrismaApi/PrismaApi.Api/PrismaApi.Api.csproj"
        ],
        "isBackground": true,
        "problemMatcher": {
            "owner": "custom",
            "pattern": {
                "regexp": "^$"
            },
            "background": {
                "activeOnStart": true,
                "beginsPattern": "^dotnet watch",
                "endsPattern": "Application started\\.|Content root path:"
            }
        }
        }
  ]
}
